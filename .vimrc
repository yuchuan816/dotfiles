" ====================================================================
" 基础视觉与显示设置
" ====================================================================
syntax on            " 开启语法高亮，让代码五颜六色
set number           " 在左侧显示行号
set showmode         " 在底部显示当前处于什么模式（插入/正常/可视）
set background=dark  " 告诉 Vim 你使用的是深色终端背景，优化颜色配色
set laststatus=2     " 总是显示状态栏（即便只有一个文件）

" ====================================================================
" 搜索增强
" ====================================================================
set hlsearch         " 高亮显示所有搜索到的匹配项
set incsearch        " 输入字符时实时跳转到第一个匹配点，不用等按回车
set ignorecase       " 搜索时忽略大小写
set smartcase        " 聪明模式：如果搜小写则忽略大小写，如果搜包含大写的词则精确匹配

" ====================================================================
" 缩进与格式
" ====================================================================
set tabstop=4        " 一个 Tab 占用 4 个空格的宽度
set shiftwidth=4     " 自动缩进时，每一级的宽度为 4 个空格
set expandtab        " 将 Tab 键自动转换为空格（避免在不同编辑器里排版乱掉）
set autoindent       " 换行时，自动保持与上一行相同的缩进
set smartindent      " 插入新行时尝试智能缩进（例如在 '{' 之后）

" ====================================================================
" 操作感优化
" ====================================================================
set mouse=a          " 开启鼠标支持：可以用滚轮翻页，用鼠标点选光标位置
set scrolloff=5      " 光标移动到屏幕顶部或底部时，保持 5 行的余量（视野更广）
set backspace=indent,eol,start " 解决部分系统下退格键(Backspace)无法删除字符的问题
if has('clipboard')
    set clipboard=unnamed,unnamedplus " 尝试让 Vim 的剪贴板和系统剪贴板同步
endif

" ====================================================================
" 快捷键映射
" ====================================================================
" 定义 Leader 键为空格 (Space)
let mapleader = "\<Space>"

" --- 模式切换 ---
" 在插入模式下，快速输入 jk 即可退回到普通模式
inoremap jk <Esc>

" --- 搜索优化 ---
" 连按两次 Esc 取消搜索高亮显示
nnoremap <Esc><Esc> :noh<CR>

" --- 窗口管理 (针对 C 语言多文件查看) ---
" 水平拆分窗口：空格 + s
nnoremap <Leader>s :split<CR>
" 垂直拆分窗口：空格 + v
nnoremap <Leader>v :vsplit<CR>

" --- 跳转增强 ---
" 配合 ctags/lsp 跳转到定义：空格 + d
nnoremap <Leader>d <C-]>
" 返回跳转前的位置（配合跳转后使用）：空格 + b
nnoremap <Leader>b <C-o>

" 针对嵌入式开发：显示 Tab 符和行尾空格（防止代码风格混乱）
" 输入 :set list 开启，输入 :set nolist 关闭
set listchars=tab:»\ ,trail:·

" ====================================================================
" 文件类型检测与插件
" ====================================================================
filetype plugin indent on    " 自动检测文件类型，加载插件和缩进规则

" ====================================================================
" 备份与撤销增强
" ====================================================================
set undofile             " 启用持久化撤销（关闭文件后仍能撤销）
set undodir=~/.vim/undo  " 撤销历史存放目录

" 自动创建撤销目录（如果不存在）
if !isdirectory(expand("~/.vim/undo"))
    call mkdir(expand("~/.vim/undo"), "p")
endif

" ====================================================================
" 性能优化
" ====================================================================
set lazyredraw           " 宏执行时不重绘，加快速度
set ttyfast              " 告诉 Vim 终端连接速度快

" ====================================================================
" 代码折叠
" ====================================================================
set foldmethod=indent    " 按缩进自动折叠
set foldlevel=99         " 默认不折叠，手动 zr/zm 控制

" ====================================================================
" 状态栏增强
" ====================================================================
set ruler                " 显示光标位置（行，列）
set statusline=%f\ %y\ %l/%L\ %c\ %P  " 文件名/类型/行号/总行/列/百分比

" ====================================================================
" 更多实用快捷键
" ====================================================================
" --- 快速跳转 ---
" 跳转到行首（保留缩进）：空格 + h
nnoremap <Leader>h ^
" 跳转到行尾：空格 + l
nnoremap <Leader>l $

" --- 文本操作 ---
" 选中当前单词：空格 + w
nnoremap <Leader>w viw

" --- 代码块调整 ---
" 可视模式下选中代码块，按 < 或 > 缩进并重新选中
vnoremap < <gv
vnoremap > >gv

" ====================================================================
" 编码设置（防止中文乱码）
" ====================================================================
set encoding=utf-8
set fileencodings=utf-8,gbk,latin1
